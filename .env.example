GOOGLE_MAPS_API_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Public canonical origin (no trailing slash). Used by SSR routes & sitemaps.
NEXT_PUBLIC_SITE_URL=https://www.dukkanci.com.tr

# Google Indexing API service-account credentials (set in Vercel, never commit real values).
# PRIVATE_KEY keeps the literal "\n" sequences; the code converts them to newlines.
GOOGLE_INDEXING_CLIENT_EMAIL=
GOOGLE_INDEXING_PRIVATE_KEY=

# Direct Postgres connection (optional — the app reads via the Supabase REST API above).
DATABASE_URL=

# --- WhatsApp Cloud API: order notifications via the platform number ---
# (See WHATSAPP_SETUP.md for the full activation guide.)
# From Meta App > WhatsApp > API Setup. Use a PERMANENT System-User token, not the 24h test token.
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v21.0
# Country code prepended to local numbers (Turkey = 90).
WHATSAPP_DEFAULT_COUNTRY_CODE=90
# Approved message-template names + language. Required to message users outside the 24h window.
# Leave blank to send plain text (only works within the 24h window — for testing).
WHATSAPP_TEMPLATE_STORE=
WHATSAPP_TEMPLATE_CUSTOMER=
WHATSAPP_TEMPLATE_LANG=ar
# Any random string; paste the same value into Meta's webhook config screen.
WHATSAPP_VERIFY_TOKEN=
# Optional: shared secret required on /api/notify-order (set it on a Supabase DB webhook header).
NOTIFY_SECRET=
# Optional: service-role key for server-side DB reads/writes (falls back to the anon key).
SUPABASE_SERVICE_ROLE_KEY=
