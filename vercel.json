{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/delivery-quote.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/api/sitemap" },
    { "source": "/sitemap-stores.xml", "destination": "/api/sitemap-stores" },
    { "source": "/sitemap-products.xml", "destination": "/api/sitemap-products" },
    { "source": "/sitemap-categories.xml", "destination": "/api/sitemap-categories" },
    { "source": "/store/:id", "destination": "/api/store?id=:id" },
    { "source": "/product/:slug", "destination": "/api/product?slug=:slug" },
    { "source": "/category/:slug", "destination": "/api/category?slug=:slug" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
